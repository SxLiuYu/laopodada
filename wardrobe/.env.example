# 复制为 .env 并按需修改
# 应用配置
HOST=0.0.0.0
PORT=5050
DEBUG=0

# 模型目录（默认 ~/wardrobe_models/）
# Mac 本地运行时: WARDROBE_MODELS_DIR=~/Models
# Linux 云端运行时: WARDROBE_MODELS_DIR=/opt/llm_models
WARDROBE_MODELS_DIR=~/Models

# ============= 混合 AI 模式 (推荐) =============
# 在 Mac mini 跑 mac_services/ 里的微服务, 然后填入 Tailscale 私网 IP
# 留空 = 本地加载 / 纯规则模式
#
# LLM_REMOTE_URL=http://100.x.x.x:8001        # Mac mini 端 llm_service.py
# FASHION_CLIP_REMOTE_URL=http://100.x.x.x:8002  # Mac mini 端 visual_service.py

# 单个模型路径（一般不用改，AI 模块会按 platform 拼接）
# FASHION_CLIP_DIR=/path/to/marqo-fashionCLIP
# LLM_MODEL_DIR=/path/to/Qwen3-4B-Thinking-2507-MLX-4bit
